{
  "name": "forecast-kit",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/providers/*"
  ],
  "bin": {
    "forecast-kit": "./apps/cli/src/index.tsx"
  },
  "scripts": {
    "dev": "bun run apps/cli/src/index.tsx",
    "serve": "bun run apps/api/src/index.ts",
    "ui:app": "bun run --filter @forecast-kit/ui dev",
    "ui": "bun run scripts/dev-explore.ts",
    "ui:build": "bun run --filter @forecast-kit/ui build",
    "dev:explore": "bun run ui",
    "sync:kalshi": "bun run apps/cli/src/index.tsx sync kalshi --no-ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.16",
    "@types/node": "^22.15.29",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  }
}
